# Deep Infra API token (https://deepinfra.com/dash/api_keys)
DEEPINFRA_TOKEN=your-deepinfra-token-here

# TTS engine selection (currently: deepinfra_kokoro)
TTS_ENGINE=deepinfra_kokoro

# Default Kokoro voice (e.g. af_bella, af_sarah, am_adam, bf_emma)
TTS_VOICE=af_bella

# Comma-separated list of allowed CORS origins for the API
CORS_ORIGINS=http://localhost:5173

# Enable word-level alignment for karaoke (true/false).
# When false, evenly-distributed timings are used (no WhisperX needed).
ENABLE_ALIGNMENT=true
